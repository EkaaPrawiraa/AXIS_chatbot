# ===== Companionship ChatBot .gitignore =====

# ---------- Environment / Secrets ----------
.env
.env.dev
.env.local
.env.*.local
!.env.example
!**/.env.example

# Google Cloud Console's own download filename for OAuth client
# credentials (contains client_secret in plaintext) -- never commit.
client_secret_*.json

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
*.egg
.pytest_cache
backups/

# ---------- Go ----------
# Compiled binary (backend/api)
backend/api
*.exe
*.out

# ---------- Node / Frontend ----------
node_modules/
/.next/
frontend/.next/
/out/
.pnp
.pnp.js


# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
*.pem

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Postman (local state) ----------
.postman/

# ---------- Markdown (only commit README.md) ----------
*.md
!README.md
*.docx

# ---------- Local-only docs (kept on disk, not pushed) ----------
docs/*
!docs/thesis_latex/
!docs/thesis_review/
!docs/thesis_review/features/
!docs/thesis_review/features/*.md
!docs/thesis_review/evaluasi-*.md


# ---------- Dev/debug scratch scripts ----------
frontend_v2/scripts/
agentic/tmp/
agentic/agentic/tmp/
frontend/
scripts/
!docs/thesis_latex/evaluasi_v2/scripts/
!docs/thesis_latex/evaluasi_v2/scripts/*.py
/docs/thesis_latex/evaluasi_v2/rm3_memori/external_data/*.json
# ---------- Synthetic Chat Eval Output ----------
utility/synthetic_chat_eval/output/

# ---------- Misc ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/coverage
*.tsbuildinfo
next-env.d.ts
.vercel
dashboard.txt

# ---------- Evaluation pipeline generated/local data ----------
evaluation_pipeline/.env
evaluation_pipeline/__pycache__/
evaluation_pipeline/tests/__pycache__/
evaluation_pipeline/logs/
evaluation_pipeline/results/
evaluation_pipeline/runs/
evaluation_pipeline/*.bak
evaluation_pipeline/graph.png
evaluation_pipeline/budi.md

# ---------- WhatsApp Bot (local session) ----------
whatsapp_bot/auth/


.webui_secret_key
schema.sql
.testing
.dump
bab1_reference
axis_remaining_evaluation