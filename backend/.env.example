# CompanionshipChatBot backend example environment
# Copy to .env and adjust for your local machine.

HTTP_PORT_MAIN=3001
HTTP_PORT_AUTH=8083
HTTP_PORT_CHAT=8081
HTTP_PORT_MEMORY=8082
LOG_LEVEL=debug

POSTGRES_DSN=postgres://companion:devpassword@localhost:5433/companion_chatbot?sslmode=disable
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yourpassword
NEO4J_MAX_POOL_SIZE=50
NEO4J_ACQUIRE_TIMEOUT=60s
NEO4J_TX_RETRY_TIME=30s

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

AGENTIC_BASE_URL=http://localhost:8000
AGENTIC_GATEWAY_PRIVATE_KEY=dev-secret
JWT_SECRET=dev-secret-change-in-production
# Add the public frontend origin here when reverse proxy is in place.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002
PUBLIC_AGENTIC_PROXY_ENABLED=0
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

ELEVENLABS_API_KEY=CHANGE_ME

AUTH_SERVICE_URL=http://localhost:8083
CHAT_SERVICE_URL=http://localhost:8081
MEMORY_SERVICE_URL=http://localhost:8082
