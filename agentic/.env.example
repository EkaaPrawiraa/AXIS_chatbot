# CompanionshipChatBot - agentic environment example
# Copy to .env and fill secrets locally.

LOG_LEVEL=info
DEFAULT_USER_LANGUAGE=id
GUARDRAIL_AUDIT_ENABLED=1
AGENTIC_HOST=0.0.0.0
AGENTIC_PORT=8000
AGENTIC_RELOAD=0
AGENTIC_ENABLE_DOCS=0
AGENTIC_LOG_LEVEL=info
AGENTIC_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AXIS_GRAPH_STATE_LOG=off
AXIS_GRAPH_TIMING_LOG=0
# v2 = single-stage response_generator; v3 = adds understanding_synthesis
# as a separate reasoning stage before response_generator.
AXIS_RESPONSE_PIPELINE_VERSION=v3
PGVECTOR_SYNC_ENABLED=1
PGVECTOR_SYNC_INTERVAL_SECONDS=300
PGVECTOR_SYNC_BATCH_SIZE=100
SESSION_SWEEPER_ENABLED=1
SWEEPER_IDLE_MINUTES=30
SWEEPER_POLL_INTERVAL_SECONDS=60
SWEEPER_BATCH_LIMIT=25
SWEEPER_CHECKPOINT_MESSAGE_THRESHOLD=16
SWEEPER_RECOVERY_ENABLED=1
SWEEPER_RECOVERY_INTERVAL_HOURS=12
SWEEPER_RECOVERY_COOLDOWN_HOURS=12
RETRIEVAL_MODE=full
RETRIEVAL_QUERY_REWRITE_ENABLED=1

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yourpassword
NEO4J_DATABASE=neo4j
NEO4J_POOL_SIZE=50

PG_HOST=localhost
PG_PORT=5433
PG_USER=companion
PG_PASSWORD=devpassword
PG_DATABASE=companion_chatbot
PG_POOL_MIN_SIZE=1
PG_POOL_MAX_SIZE=10

EMBED_PROVIDER=
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536
OLLAMA_BASE_URL=http://127.0.0.1:11434

LLM_PROVIDER=openai
OPENAI_API_KEY=GANTII
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
GOOGLE_API_KEY=GANTII
GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite
GEMINI_MODEL_STRONG=gemini-3.5-flash
GEMINI_MODEL_STRONG_GENERATION=gemini-3.5-flash
GEMINI_MODEL_KG_EXTRACTOR=gemini-3.5-flash
GEMINI_RETRIEVAL_QUERY_REWRITER_MODEL=gemini-3.1-flash-lite
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_API_KEY=not-needed
LOCAL_MODEL_CHEAP=mlx-community/Qwen2.5-1.5B-Instruct-4bit
LOCAL_MODEL_STRONG=mlx-community/Qwen2.5-1.5B-Instruct-4bit
LOCAL_MODEL_STRONG_GENERATION=mlx-community/Qwen2.5-1.5B-Instruct-4bit
LOCAL_MODEL_KG_EXTRACTOR=mlx-community/Qwen2.5-1.5B-Instruct-4bit
LOCAL_RETRIEVAL_QUERY_REWRITER_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit
LLM_MODEL_CHEAP=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o-mini
RETRIEVAL_QUERY_REWRITER_MODEL=gpt-4o-mini

OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
ELEVENLABS_API_KEY=GANTII
ELEVENLABS_MODEL_REALTIME=eleven_flash_v2_5
ELEVENLABS_MODEL_PRERENDERED=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.64
ELEVENLABS_SIMILARITY_BOOST=1.0
ELEVENLABS_STYLE=0.12
ELEVENLABS_USE_SPEAKER_BOOST=true
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_FORMAT=mp3

# Third-tier TTS fallback (ElevenLabs -> OpenAI -> Gemini) and STT fallback
# (OpenAI -> Gemini), reusing GOOGLE_API_KEY above.
GEMINI_TTS_MODEL=gemini-3.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_TRANSCRIBE_MODEL=gemini-3.5-flash

# response_generator: Gemini-only tools (active when LLM_PROVIDER=gemini).
# Google Search grounding needs no model config (bound as a native tool);
# url_context uses the google-genai SDK directly (bypasses LangChain).
GEMINI_URL_CONTEXT_MODEL=gemini-3.5-flash

TAVILY_API_KEY=GANTII
OPENAI_WEBSEARCH_MODEL=gpt-4o-mini-search-preview
AGENTIC_GATEWAY_PRIVATE_KEY=dev-secret
AGENTIC_GATEWAY_PRIVATE_KEY_HEADER=X-Agentic-Private-Key
OPENWEBUI_ADAPTER_API_KEY=

AXIS_RESPONSE_MODEL_TEST_MESSAGE=Apa yang lu inget tentang gua
AXIS_RUN_RESPONSE_MODEL_BENCHMARK=1
AXIS_RUN_REAL_FINALIZER=1
AXIS_GRAPH_IMAGE_PATH=graph.png
AXIS_GRAPH_IMAGE_BG=white
AXIS_GRAPH_IMAGE_PADDING=24
AXIS_GRAPH_IMAGE_WRAP_WORDS=6
AXIS_GRAPH_IMAGE_THEME=dark
AXIS_GRAPH_IMAGE_FONT_FAMILY=ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto
