              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"session_id\": \"proxy-test-001\",\n  \"current_message\": \"halo dari proxy\",\n  \"messages\": [],\n  \"session_turn\": 1,\n  \"language_pref\": \"id\"\n}"
            },
            "description": "Direct LangGraph call through gateway. Bypasses chat service (no DB persistence). The gateway injects AGENTIC_GATEWAY_PRIVATE_KEY itself, so Postman does not need it."
          }
