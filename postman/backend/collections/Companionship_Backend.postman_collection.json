              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"content\": \"\",\n  \"language_pref\": \"id\",\n  \"voice\": {\n    \"output_modality\": \"both\",\n    \"audio_input_base64\": \"<base64-audio>\",\n    \"audio_input_mime\": \"audio/webm\",\n    \"voice_id\": \"\",\n    \"tts_model\": \"v2_5_turbo\"\n  }\n}"
            },
            "description": "Voice turn. STT → LangGraph → TTS. Replace audio_input_base64 with a real recording. output_modality: text | voice | both."
          }
        },
