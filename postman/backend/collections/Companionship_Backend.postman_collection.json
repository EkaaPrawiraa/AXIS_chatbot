              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"content\": \"ceritakan sedikit tentang dirimu\",\n  \"language_pref\": \"id\"\n}"
            },
            "description": "SSE streaming variant of /messages/send. Events: token (text chunk), done (full SendMessageOutput JSON), error. Voice turns are not supported on this path."
          }
        }
      ]
    },
