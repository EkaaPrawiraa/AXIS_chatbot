# Infrastructure (secrets belong in .env and must never be committed)
DATABASE_URL=postgresql://companion:devpassword@localhost:5433/companion_chatbot
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Provider credentials: only keys required by selected providers need values.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Controlled baseline experiment
EVAL_AXIS_PROVIDER=gemini
EVAL_BASELINE_PROVIDER=gemini
EVAL_BASELINE_MODEL=gemini-2.5-flash
EVAL_BASELINE_TEMPERATURE=0.7
EVAL_BASELINE_MAX_TOKENS=700

# Exploratory simulated-user mode (not used by evaluate.py scripted protocol)
EVAL_SIMULATOR_PROVIDER=gemini
EVAL_SIMULATOR_MODEL=gemini-2.5-flash-lite
EVAL_SIMULATOR_TEMPERATURE=0.8
EVAL_SIMULATOR_MAX_TOKENS=100

# Must match the vectors stored by the application
EVAL_EMBEDDING_PROVIDER=gemini
EVAL_EMBEDDING_MODEL=gemini-embedding-001
EVAL_EMBEDDING_DIMENSION=1536
EVAL_TOP_K=5

# Reproducibility
EVAL_RANDOM_SEED=20260710
EVAL_SEND_PROVIDER_SEED=0
EVAL_REPETITIONS=3
EVAL_REQUEST_TIMEOUT_SECONDS=90
# EVAL_RESULTS_DIR=/absolute/path/to/evaluation_pipeline/runs

# Optional standalone HTTP domain test
AGENTIC_URL=http://localhost:8000
AGENTIC_GATEWAY_PRIVATE_KEY=
