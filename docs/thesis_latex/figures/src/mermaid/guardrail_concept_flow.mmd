flowchart TB
    A([Mulai])
    B[Pesan pengguna diterima]
    C[Periksa risiko eksplisit]
    D{Ada risiko eksplisit?}
    E[Periksa risiko implisit dan konteks]
    F{Tingkat risiko}
    G[Respons percakapan normal]
    H[Dukungan reflektif non-klinis]
    I[Rujukan bantuan dan hotline]
    J[Catat keputusan keselamatan]
    K([Selesai])

    A --> B --> C --> D
    D -->|Tidak| E --> F
    D -->|Ya| F
    F -->|Tidak ada| G --> J
    F -->|Perlu perhatian| H --> J
    F -->|Tinggi| I --> J
    J --> K

    classDef terminator fill:#ffffff,stroke:#111111,stroke-width:1.4px,color:#111111;
    classDef process fill:#ffffff,stroke:#111111,stroke-width:1.2px,color:#111111;
    classDef decision fill:#f2f2f2,stroke:#111111,stroke-width:1.2px,color:#111111;
    class A,K terminator;
    class B,C,E,G,H,I,J process;
    class D,F decision;
